{
  "page_id": "home",
  "version": "3.0.0",
  "data_sources": {
    "modules_manifest": "data/modules-manifest.json",
    "community_feed": "data/community-feed.json",
    "draws_csv": "archives/draws/draws.csv",
    "iargos_public_status": "data/iargos-public-status.json"
  },
  "kpi_items": [
    {
      "id": "kpi-archive",
      "title": "Archivio",
      "value": "Storico completo",
      "meta": "Estrazioni verificate e consultabili",
      "tone": "archive",
      "href": "pages/storico-estrazioni/index.html"
    },
    {
      "id": "kpi-focus",
      "title": "Focus",
      "value": "Pattern e anomalie",
      "meta": "Segnali deboli e derive statistiche",
      "tone": "focus",
      "href": "pages/laboratorio-tecnico/index.html"
    },
    {
      "id": "kpi-study",
      "title": "Studi",
      "value": "Paper tecnici live",
      "meta": "Metodi, assunti, limiti e risultati",
      "tone": "study",
      "href": "pages/algoritmi/index.html"
    }
  ],
  "zones": [
    {
      "id": "hero-status-zone",
      "type": "hero_status",
      "mount": "[data-home-live-status]"
    },
    {
      "id": "news-zone",
      "type": "news_cards",
      "mount": "[data-module-area]",
      "limit": 8
    },
    {
      "id": "kpi-zone",
      "type": "kpi_cards",
      "mount": "[data-kpi-cards]"
    },
    {
      "id": "proposals-zone",
      "type": "proposals_list",
      "mount": "[data-home-proposals]"
    },
    {
      "id": "active-algorithms-zone",
      "type": "active_algorithms",
      "mount": "[data-home-active-algorithms]",
      "limit": 6
    },
    {
      "id": "trend-zone",
      "type": "trend_numbers",
      "mount": "[data-home-trends]"
    },
    {
      "id": "community-zone",
      "type": "community_activity",
      "mount": "[data-home-community]"
    }
  ]
}

